# Copy to .env and fill in your values. Do not commit .env.

DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
DB_NAME=recruitment_portal
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery (optional; leave as-is for local Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (e.g. Gmail; use an App Password, not your normal password)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# OTP
OTP_EXPIRY_MINUTES=15
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6

# Upload limits
MAX_UPLOAD_FILE_SIZE_MB=10

# CORS (if frontend runs on different origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Dynamics 365 F&O - full Applicant Import endpoint (SubmitApplicant)
# Example: https://your-d365-instance.operations.dynamics.com/api/services/POSBRecruitmentServiceGroup/POSBRecruitmentService/SubmitApplicant
DYNAMICS_365_API_URL=
# Optional override for Azure token resource (base env URL only, no /api/services path)
# Example: https://your-d365-instance.operations.dynamics.com
DYNAMICS_365_RESOURCE_URL=
DYNAMICS_365_CLIENT_ID=your-azure-ad-app-client-id
DYNAMICS_365_CLIENT_SECRET=your-azure-ad-app-client-secret
DYNAMICS_365_TENANT_ID=your-azure-ad-tenant-id
# HTTP timeout for D365 SubmitApplicant call
DYNAMICS_365_HTTP_TIMEOUT_SECONDS=120
# true = auto push to D365 right after submit (async); false = manual push only
D365_PUSH_ON_SUBMISSION=true
