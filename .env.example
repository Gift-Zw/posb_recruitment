# Copy to .env and fill in your values. Do not commit .env.

DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=127.0.0.1,localhost

# Database
DB_NAME=recruitment_portal
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery (optional; leave as-is for local Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email (e.g. Gmail; use an App Password, not your normal password)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# OTP
OTP_EXPIRY_MINUTES=15
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6

# CORS (if frontend runs on different origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Dynamics 365 (optional; for future integration)
DYNAMICS_365_API_URL=
DYNAMICS_365_CLIENT_ID=
DYNAMICS_365_CLIENT_SECRET=
DYNAMICS_365_TENANT_ID=
